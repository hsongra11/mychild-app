{
  "name": "mychild-engine",
  "version": "0.3.0",
  "description": "Open-source developmental screening engine with evidence-weighted escalation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mychild-engine": "dist/cli.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "developmental-screening",
    "child-development",
    "milestones",
    "pediatric",
    "health",
    "screening-engine",
    "corrected-age",
    "preterm",
    "cdc-milestones"
  ],
  "author": "Harsh Songra <harsh@airpulse.dev> (https://harshsongra.com)",
  "contributors": [
    "Aafreen Ansari (https://linkedin.com/in/aafreen-ansari-8a4265112)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hsongra11/mychild-app.git",
    "directory": "packages/engine"
  },
  "homepage": "https://mychildapp.in",
  "bugs": {
    "url": "https://github.com/hsongra11/mychild-app/issues"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
